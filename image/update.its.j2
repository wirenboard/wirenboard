/dts-v1/;

/ {
    description = "WirenBoard firmware update";
    compatible = "{{ COMPATIBLE }}";
    firmware-version = "{{ FIRMWARE_VERSION }}";
    firmware-compatible = "{{ FIRMWARE_COMPATIBLE }}";
    release-name = "{{ RELEASE_NAME }}";
    release-suite = "{{ RELEASE_SUITE }}";
    release-target = "{{ RELEASE_TARGET }}";
    release-repo-prefix = "{{ RELEASE_REPO_PREFIX }}";
    #address-cells = <1>;
    images {
        kernel {
            description = "Update kernel";
            data = /incbin/("{{ KERNEL_DATA }}");
            type = "kernel";
            os = "linux";
            arch = "arm";
            compression = "none";

            hash@1 {
                algo = "sha1";
            };
        };
        dtb {
            description = "Update DTB";
            data = /incbin/("{{ DTB_DATA }}");
            type = "flat_dt";
            arch = "arm";
            compression = "none";

            hash@1 {
                algo = "sha1";
            };
        };
        install {
            description = "Installation script (bash)";
            data = /incbin/("{{ INSTALL_DATA }}");
            compression = "none";

            hash@1 {
                algo = "sha1";
            };
        };
        rootfs {
            description = "Root filesystem tarball";
            data = /incbin/("{{ ROOTFS_DATA }}");
            compression = "none";

            hash@1 {
                algo = "sha1";
            };
        };
    };
    configurations {
    };
};
